generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  specialty      String
  role           UserRole       @default(PHYSICIAN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  patients       Patient[]
  refreshTokens  RefreshToken[]

  @@index([email])
}

enum UserRole {
  ADMIN
  PHYSICIAN
  NURSE
  RECEPTIONIST
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  consumed  Boolean   @default(false)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Patient {
  id                    String                  @id @default(cuid())
  userId                String
  firstName             String
  lastName              String
  age                   Int
  gender                String
  bloodType             String?
  allergies             String[]                @default([])
  pastMedicalHistory    String[]                @default([])
  presentingComplaint   String?
  durationOfIllness     String?
  systemicReview        String?
  examFindings          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  differentialDiagnoses DifferentialDiagnosis[]
  investigations        Investigation[]
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments            Treatment[]
  vitals                Vital[]
  clinicalNotes         ClinicalNote[]

  @@index([userId])
}

model Vital {
  id                     String   @id @default(cuid())
  patientId              String
  temperature            Float?
  pulse                  Int?
  respiratoryRate        Int?
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  oxygenSaturation       Float?
  bloodGlucose           Float?   // New: Blood glucose in mg/dL
  weight                 Float?   // New: Weight in kg
  height                 Float?   // New: Height in cm
  notes                  String?
  recordedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  patient                Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([recordedAt])
}

model DifferentialDiagnosis {
  id                    String   @id @default(cuid())
  patientId             String
  diagnosis             String
  probability           Float
  reasoning             String
  goldStandardReference String
  createdAt             DateTime @default(now())
  patient               Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Investigation {
  id             String    @id @default(cuid())
  patientId      String
  name           String
  type           String
  status         String
  requestedAt    DateTime  @default(now())
  resultAt       DateTime?
  result         String?
  normalRange    String?
  interpretation String?
  createdAt      DateTime  @default(now())
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
}

model Treatment {
  id           String    @id @default(cuid())
  patientId    String
  medicineId   String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  status       String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  medicine     Medicine  @relation(fields: [medicineId], references: [id])
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([medicineId])
  @@index([status])
}

model Medicine {
  id                String      @id @default(cuid())
  name              String      @unique
  type              String
  uses              String[]
  dosage            String
  sideEffects       String[]    @default([])
  contraindications String[]    @default([])
  createdAt         DateTime    @default(now())
  treatments        Treatment[]

  @@index([type])
}

model Disease {
  id                 String   @id @default(cuid())
  name               String
  icdCode            String   @unique
  specialty          String
  definition         String
  pathophysiology    String
  epidemiology       String
  symptoms           String[] @default([])
  signs              String[] @default([])
  diagnosticCriteria String[] @default([])
  investigations     String[] @default([])
  management         String
  prognosis          String
  reference          String
  vitalSigns         Json?    // Expected vital sign ranges: {bp: {sys: "120-130", dia: "80-90"}, hr: "60-100", temp: "37-38", glucose: "90-120"}
  createdAt          DateTime @default(now())

  @@index([specialty])
  @@index([icdCode])
}

model Symptom {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  system      String   // e.g., "Respiratory", "Gastrointestinal", "Neurological"
  severity    String?  // Optional: mild, moderate, severe
  createdAt   DateTime @default(now())

  @@index([system])
}

model Sign {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  system      String   // e.g., "Cardiovascular", "Respiratory", "Neurological"
  examination String?  // Type of examination needed: auscultation, palpation, etc.
  createdAt   DateTime @default(now())

  @@index([system])
}

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ClinicalNote {
  id        String    @id @default(cuid())
  patientId String
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  title     String
  content   String    @db.Text
  tags      String[]  @default([])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([patientId])
}
