generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  specialty String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  Patient[]

  @@index([email])
}

model Patient {
  id                    String                  @id @default(cuid())
  userId                String
  firstName             String
  lastName              String
  age                   Int
  gender                String
  bloodType             String?
  allergies             String[]                @default([])
  pastMedicalHistory    String[]                @default([])
  presentingComplaint   String?
  durationOfIllness     String?
  systemicReview        String?
  examFindings          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  differentialDiagnoses DifferentialDiagnosis[]
  investigations        Investigation[]
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments            Treatment[]
  vitals                Vital[]

  @@index([userId])
}

model Vital {
  id                     String   @id @default(cuid())
  patientId              String
  temperature            Float?
  pulse                  Int?
  respiratoryRate        Int?
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  oxygenSaturation       Float?
  recordedAt             DateTime @default(now())
  notes                  String?
  createdAt              DateTime @default(now())
  patient                Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([recordedAt])
}

model DifferentialDiagnosis {
  id                    String   @id @default(cuid())
  patientId             String
  diagnosis             String
  probability           Float
  reasoning             String
  goldStandardReference String
  createdAt             DateTime @default(now())
  patient               Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Investigation {
  id             String    @id @default(cuid())
  patientId      String
  name           String
  type           String
  status         String
  requestedAt    DateTime  @default(now())
  resultAt       DateTime?
  result         String?
  normalRange    String?
  interpretation String?
  createdAt      DateTime  @default(now())
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
}

model Treatment {
  id           String    @id @default(cuid())
  patientId    String
  medicineId   String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  status       String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  medicine     Medicine  @relation(fields: [medicineId], references: [id])
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([medicineId])
  @@index([status])
}

model Medicine {
  id                String      @id @default(cuid())
  name              String      @unique
  type              String
  uses              String[]
  dosage            String
  sideEffects       String[]    @default([])
  contraindications String[]    @default([])
  createdAt         DateTime    @default(now())
  treatments        Treatment[]

  @@index([type])
}

model Disease {
  id                 String   @id @default(cuid())
  name               String
  icdCode            String   @unique
  specialty          String
  definition         String
  pathophysiology    String
  epidemiology       String
  symptoms           String[] @default([])
  signs              String[] @default([])
  diagnosticCriteria String[] @default([])
  investigations     String[] @default([])
  management         String
  prognosis          String
  reference          String
  createdAt          DateTime @default(now())

  @@index([specialty])
  @@index([icdCode])
}

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
}
