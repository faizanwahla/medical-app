{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "packages/web/dist",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "packages/web/dist/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/medical-app/(.*)",
      "destination": "/medical-app/$1"
    },
    {
      "source": "/medical-app",
      "destination": "/medical-app/"
    },
    {
      "source": "/medical-app/((?!assets/).*)$",
      "destination": "/medical-app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/medical-app/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/medical-app/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "env": [
    "DATABASE_URL",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "NODE_ENV",
    "CORS_ORIGIN"
  ]
}